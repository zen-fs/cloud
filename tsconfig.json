{
	"compilerOptions": {
		"module": "NodeNext",
		"target": "ES2020",
		"rootDir": "src",
		"outDir": "dist",
		"lib": ["ESNext"],
		"moduleResolution": "NodeNext",
		"declaration": true,
		"strict": true,
		"verbatimModuleSyntax": true,
		"types": ["gapi", "gapi.client.drive-v3"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"],
	"typedocOptions": {
		"entryPoints": ["./src/index.ts"],
		"name": "ZenFS Cloud",
		"out": "docs",
		"excludeReferences": true
	}
}
